<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/qurio_navigation"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/exampleFragment"
        android:name="com.thechance.qurio.presentation.screen.example.ExampleFragment"
        android:label="ExampleFragment" />

    <fragment
        android:id="@+id/gameFragment"
        android:name="com.thechance.qurio.presentation.screen.games_screen.GamesFragment"
        android:label="GameFragment" >
        <action
            android:id="@+id/action_gameFragment_to_homeFragment"
            app:destination="@id/homeFragment" />
    </fragment>

    <fragment
        android:id="@+id/playedGamesFragment"
        android:name="com.thechance.qurio.presentation.screen.played_games_screen.PlayedGamesFragment"
        android:label="PlayedGamesFragment" />

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.thechance.qurio.presentation.screen.home.HomeFragment"
        android:label="HomeFragment" >
        <action
            android:id="@+id/action_homeFragment_to_gameFragment"
            app:destination="@id/gameFragment" />
    </fragment>
</navigation>