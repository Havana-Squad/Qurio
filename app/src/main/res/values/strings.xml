    <!-- Characters Descriptions -->
    <string name="nature_s_little_explorer_rika_talks_to_mushrooms_and_swears_squirrels_give_her_battle_advice_always_ready_for_an_adventure">Nature’s little explorer! Rika talks to mushrooms and swears squirrels give her battle advice. Always ready for an adventure.</string>
    <string name="a_calm_storm_in_human_form_kaiyo_trains_with_ancient_scrolls_by_day_and_drinks_spicy_tea_by_night_sword_sharp_heart_sharper">A calm storm in human form. Kaiyo trains with ancient scrolls by day and drinks spicy tea by night. Sword sharp, heart sharper.</string>
    <string name="tiny_but_terrifying_mimi_is_always_grumpy_but_don_t_let_that_scare_you_unless_you_like_pranks_involving_firecrackers">Tiny but terrifying! Mimi is always grumpy, but don’t let that scare you—unless you like pranks involving firecrackers.</string>
    <string name="quiet_mysterious_and_probably_watching_you_right_now_yoru_shows_up_when_you_least_expect_it">Quiet, mysterious, and probably watching you right now. Yoru shows up when you least expect it.</string>
    <string name="cool_jacket_cooler_moves_kuro_never_backs_down_from_a_challenge">Cool jacket, cooler moves. Kuro never backs down from a challenge .</string>
    <string name="energetic_cheerful_and_faster_than_a_leaf_in_the_wind_miko_can_turn_any_trivia_into_a_giggle_fest">Energetic, cheerful, and faster than a leaf in the wind. Miko can turn any trivia into a giggle-fest.</string>
    <string name="the_sword_chooses_the_wielder_and_it_chose_aori_calm_focused">The sword chooses the wielder—and it chose Aori. Calm, focused.</string>
    <string name="part_magic_part_sass_nara_sparkles_even_when_she_s_mad">Part magic, part sass. Nara sparkles even when she’s mad.\n</string>
    <string name="small_but_mighty_renji_dreams_of_glory_carries_a_shield_too_big_for_him">Small but mighty! Renji dreams of glory, carries a shield too big for him.</string>

