<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Qurio.Starter" parent="Theme.SplashScreen">
        <item name="android:windowBackground">@color/surface</item>
        <item name="windowSplashScreenBackground">@color/surface</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo_inset</item>
        <item name="postSplashScreenTheme">@style/Theme.Qurio</item>
    </style>

    <!-- Base application theme. -->
    <style name="Base.Theme.Qurio" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="PrimaryButtonText">
        <item name="android:textAppearance">@style/Label.Medium</item>
        <item name="android:textColor">@color/on_primary</item>
    </style>

    <style name="TextButton">
        <item name="android:textAppearance">@style/Label.Medium</item>
        <item name="android:textColor">@color/primary</item>
    </style>

    <style name="Theme.Qurio" parent="Base.Theme.Qurio" />

    <style name="AnswerStyle">
        <item name="cornerRadius">12dp</item>
        <item name="borderWidth">1dp</item>
        <item name="cardBorderColor">@color/shade_quad</item>
    </style>

    <!-- Headline -->
    <style name="Headline">
        <item name="android:fontFamily">@font/fredoka_semibold</item>
    </style>

    <style name="Headline.Large">
        <item name="android:textSize">28sp</item>
        <item name="android:lineSpacingExtra">14sp</item>
    </style>

    <style name="Headline.Medium">
        <item name="android:textSize">24sp</item>
        <item name="android:lineSpacingExtra">12sp</item>
    </style>

    <style name="Headline.Small">
        <item name="android:textSize">20sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>


    <!-- Title -->
    <style name="Title">
        <item name="android:fontFamily">@font/fredoka_semibold</item>
    </style>

    <style name="Title.Large">
        <item name="android:textSize">20sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>

    <style name="Title.Medium">
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>

    <style name="Title.Small">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Title.XSmall">
        <item name="android:textSize">10sp</item>
    </style>


    <!-- Body -->
    <style name="Body">
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>

    <style name="Body.Large">
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>

    <style name="Body.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Body.Small">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>


    <!-- Label -->
    <style name="Label">
        <item name="android:fontFamily">@font/fredoka_medium</item>
    </style>

    <style name="Label.Large">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Label.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Label.Small">
        <item name="android:textSize">10sp</item>
        <item name="android:lineSpacingExtra">6sp</item>
    </style>

    <style name="Label.XSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

    <style name="QuestionCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:foreground">@drawable/question_card</item>
    </style>

    <style name="CutCornersCardStyle" parent="Widget.MaterialComponents.CardView">
        <item name="android:backgroundTint">@android:color/transparent</item>
        <item name="android:foreground">@drawable/cut_corner_card_shape</item>
    </style>

    <style name="Primary_Button_TextAppearance">
        <item name="android:textColor">@color/on_primary</item>
        <item name="android:fontFamily">@font/fredoka_semibold</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Primary_Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/primary_button_shape</item>
        <item name="android:textAppearance">@style/Primary_Button_TextAppearance</item>
    </style>

    <style name="Secondary_Button_TextAppearance" >
        <item name="android:fontFamily">@font/fredoka_semibold</item>
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>
    <style name="Secondary_Button" parent="Widget.AppCompat.Button">
        <item name="android:background">@drawable/secondary_button_shape</item>
        <item name="android:textAppearance">@style/Secondary_Button_TextAppearance</item>
    </style>

    <style name="OutLine" parent="Widget.AppCompat.Button">
        <item name="android:fontFamily">@font/fredoka_medium</item>
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Union" parent="Widget.AppCompat.Button">
        <item name="android:fontFamily">@font/fredoka_medium</item>
        <item name="android:background">@drawable/union_button_shape</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">16dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="difficultyLevelButton" parent="Widget.AppCompat.Button">
        <item name="android:fontFamily">@font/fredoka_medium</item>
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

</resources>