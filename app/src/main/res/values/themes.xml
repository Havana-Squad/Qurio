<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Qurio" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Qurio" parent="Base.Theme.Qurio" />


    <!-- Headline -->
    <style name="Headline">
        <item name="android:fontFamily">@font/fredoka_semibold</item>
    </style>

    <style name="Headline.Large">
        <item name="android:textSize">28sp</item>
        <item name="android:lineSpacingExtra">14sp</item>
    </style>

    <style name="Headline.Medium">
        <item name="android:textSize">24sp</item>
        <item name="android:lineSpacingExtra">12sp</item>
    </style>

    <style name="Headline.Small">
        <item name="android:textSize">20sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>


    <!-- Title -->
    <style name="Title">
        <item name="android:fontFamily">@font/fredoka_semibold</item>
    </style>

    <style name="Title.Large">
        <item name="android:textSize">20sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>

    <style name="Title.Medium">
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>

    <style name="Title.Small">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>


    <!-- Body -->
    <style name="Body">
        <item name="android:fontFamily">@font/fredoka_regular</item>
    </style>

    <style name="Body.Large">
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">10sp</item>
    </style>

    <style name="Body.Medium">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Body.Small">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>


    <!-- Label -->
    <style name="Label">
        <item name="android:fontFamily">@font/fredoka_medium</item>
    </style>

    <style name="Label.Large">
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Label.Medium">
        <item name="android:textSize">14sp</item>
        <item name="android:lineSpacingExtra">8sp</item>
    </style>

    <style name="Label.Small">
        <item name="android:textSize">10sp</item>
        <item name="android:lineSpacingExtra">6sp</item>
    </style>

    <style name="Label.XSmall">
        <item name="android:textSize">10sp</item>
        <item name="android:lineSpacingExtra">4sp</item>
    </style>

</resources>