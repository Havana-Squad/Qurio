<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="OutlineTextView">
        <attr name="outlineColor" format="color" />
        <attr name="outlineWidth" format="dimension" />
        <attr name="gradientStartColor" format="color" />
        <attr name="gradientEndColor" format="color" />
        <attr name="gradientAngle" format="integer" />

        <attr name="shadowColor" format="color" />
        <attr name="shadowRadius" format="dimension" />
        <attr name="shadowDx" format="dimension" />
        <attr name="shadowDy" format="dimension" />
    </declare-styleable>

    <declare-styleable name="TextButton">
        <attr name="textButtonEnabled" format="boolean" />
    </declare-styleable>
    <declare-styleable name="SecondaryButton">
        <attr name="secondaryButtonEnabled" format="boolean" />
    </declare-styleable>
    <declare-styleable name="PrimaryButton">
        <attr name="primaryButtonEnabled" format="boolean" />
    </declare-styleable>

    <declare-styleable name="SvgProgressView">
        <attr name="progress" format="float" />
        <attr name="centerText" format="string" />
        <attr name="android:textAppearance" />
    </declare-styleable>
    <declare-styleable name="QuestionTextCard">
        <attr name="questionText" format="string" />
        <attr name="questionNumber" format="string" />
    </declare-styleable>

    <declare-styleable name="StatisticsCustomCardView">
        <attr name="fillColor" format="color" />
        <attr name="strokeColor" format="color" />
        <attr name="strokeWidth" format="dimension" />
        <attr name="pathData" format="string|reference" />
    </declare-styleable>
    <declare-styleable name="ResultCardView">
        <attr name="resultText" format="string" />
        <attr name="blurVisible" format="boolean" />
        <attr name="starsVisible" format="boolean" />
    </declare-styleable>

    <declare-styleable name="GameCard">
        <attr name="cardSrc" format="reference" />
        <attr name="cardBorderColor" format="reference" />
        <attr name="cardBorderWidth" format="dimension" />
        <attr name="cardBottomGradient" format="reference" />
    </declare-styleable>

</resources>
