<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1D1919">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/primaryButton"
        style="@style/Primary_Button"
        android:layout_width="70dp"
        android:layout_height="44dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="16dp"
        android:text="@string/submit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/secondaryButton"
        style="@style/SecondaryButton"
        android:layout_width="70dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:text="@string/submit"
        app:layout_constraintStart_toStartOf="@id/primaryButton"
        app:layout_constraintTop_toBottomOf="@id/primaryButton" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/outline"
        style="@style/OutLine"
        android:layout_width="70dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:text="@string/submit"
        app:layout_constraintStart_toStartOf="@id/secondaryButton"
        app:layout_constraintTop_toBottomOf="@id/secondaryButton" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/union"
        style="@style/Union"
        android:layout_width="168dp"
        android:layout_height="44dp"
        android:layout_marginTop="166dp"
        android:text="@string/play_now"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/gradient_line"
        android:layout_width="270dp"
        android:layout_height="641dp"
        android:background="@drawable/gradient_line"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="-133dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/star1"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginStart="40dp"
        android:layout_marginBottom="28dp"
        android:elevation="4dp"
        android:src="@drawable/ic_star_un"
        app:layout_constraintBottom_toBottomOf="@id/union"
        app:layout_constraintStart_toStartOf="@id/union" />

    <ImageView
        android:id="@+id/star2"
        android:layout_width="8dp"
        android:layout_height="8dp"
        android:layout_marginEnd="28dp"
        android:layout_marginBottom="28dp"
        android:elevation="4dp"
        android:src="@drawable/ic_star_un"
        app:layout_constraintBottom_toBottomOf="@id/union"
        app:layout_constraintEnd_toEndOf="@id/union" />


</androidx.constraintlayout.widget.ConstraintLayout>