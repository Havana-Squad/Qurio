<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_question_text"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <androidx.cardview.widget.CardView
        android:id="@+id/card_question_card_back"
        style="@style/QuestionCardStyle"
        android:layout_width="328dp"
        android:layout_height="205dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/question_image"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_marginTop="-24dp"
        android:layout_marginEnd="8dp"
        android:elevation="1dp"
        android:scaleType="fitCenter"
        android:src=""
        app:layout_constraintBottom_toBottomOf="@id/card_question_card_back"
        app:layout_constraintEnd_toEndOf="@id/card_question_card_back"
        app:layout_constraintStart_toStartOf="@id/card_question_card_back"
        app:layout_constraintTop_toTopOf="@id/hexa"
        tools:src="@drawable/test_image" />

    <TextView
        android:id="@+id/caption"
        style="@style/Body.Medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="30dp"
        android:elevation="1dp"
        android:gravity="center"
        android:text=""
        android:textColor="@color/shade_primary"
        app:layout_constraintBottom_toBottomOf="@id/card_question_card_back"
        app:layout_constraintEnd_toEndOf="@id/question_image"
        app:layout_constraintStart_toStartOf="@id/question_image"
        tools:text="The image caption"

        />

    <ImageView
        android:id="@+id/hexa"
        android:layout_width="145dp"
        android:layout_height="40dp"
        android:layout_marginTop="-16dp"
        android:elevation="1dp"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintEnd_toEndOf="@id/card_question_card_back"
        app:layout_constraintStart_toStartOf="@id/card_question_card_back"
        app:layout_constraintTop_toTopOf="@id/card_question_card_back" />

    <TextView
        android:id="@+id/question_number_text"
        style="@style/Title.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:elevation="1dp"
        android:text=""
        android:textColor="@color/shade_primary"
        app:layout_constraintEnd_toEndOf="@id/hexa"
        app:layout_constraintStart_toStartOf="@id/hexa"
        app:layout_constraintTop_toTopOf="@id/hexa"
        tools:text="Q 1/12" />

</androidx.constraintlayout.widget.ConstraintLayout>