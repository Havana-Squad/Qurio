<?xml version="1.0" encoding="utf-8"?>
<layout  xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>
        <variable
            name="resultstate"
            type="com.thechance.qurio.presentation.screen.result_screen.ResultUiState" />
        <import type="android.view.View"/>
    </data>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="316dp"
            android:layout_height="155dp"
            android:src="@drawable/ic_result_shadow"
            android:contentDescription="@string/result_shadow"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/result_ribbon"
            android:layout_width="344dp"
            android:layout_height="69dp"
            android:src="@drawable/ic_result_ribbon"
            android:contentDescription="@string/result_ribbon"
            android:layout_marginTop="109dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:text="@string/great_job"
            style="@style/Headline.Medium"
            android:textColor="@color/on_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="118dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <ImageView
            android:id="@+id/star_1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_star"
            android:contentDescription="@string/star"
            android:layout_marginTop="75dp"
            android:visibility="@{resultstate.starsNum == 1 ? View.VISIBLE : View.GONE}"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <ImageView
            android:id="@+id/star_2_1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="75dp"
            android:contentDescription="@string/star"
            android:src="@drawable/ic_star"
            app:layout_constraintEnd_toStartOf="@id/star_2_2"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            android:id="@+id/star_2_2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_star"
            android:contentDescription="@string/star"
            android:layout_marginTop="75dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/star_2_1"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/group_2_star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="@{resultstate.starsNum == 2 ? View.VISIBLE : View.GONE}"
            app:constraint_referenced_ids="star_2_2, star_2_1" />

        <ImageView
            android:id="@+id/star_3_1"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginTop="75dp"
            android:contentDescription="@string/star"
            android:src="@drawable/ic_star"
            app:layout_constraintEnd_toStartOf="@id/star_3_2"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
        <ImageView
            android:id="@+id/star_3_2"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_star"
            android:contentDescription="@string/star"
            android:layout_marginTop="70dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/star_3_1"
            app:layout_constraintEnd_toStartOf="@id/star_3_3" />
        <ImageView
            android:id="@+id/star_3_3"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_star"
            android:contentDescription="@string/star"
            android:layout_marginTop="75dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toEndOf="@id/star_3_2"
            app:layout_constraintEnd_toEndOf="parent" />

        <androidx.constraintlayout.widget.Group
            android:id="@+id/group_3_star"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="@{resultstate.starsNum == 3 ? View.VISIBLE : View.GONE}"
            app:constraint_referenced_ids="star_3_1, star_3_2, star_3_3" />

        <TextView
            android:id="@+id/reward"
            android:text="@string/reward"
            style="@style/Title.Small"
            android:textColor="@color/shade_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/result_ribbon"
            app:layout_constraintStart_toStartOf="@id/icon_coins"
            app:layout_constraintEnd_toEndOf="@id/reward_coins"/>

        <ImageView
            android:id="@+id/icon_coins"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="2dp"
            android:contentDescription="@string/result_ribbon"
            android:src="@drawable/ic_coin_stack"
            app:layout_constraintEnd_toStartOf="@id/reward_coins"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/reward" />

        <TextView
            android:id="@+id/reward_coins"
            android:text= "@{Integer.toString(resultstate.coins)}"
            style="@style/Title.Medium"
            android:textColor="@color/shade_primary"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/reward"
            app:layout_constraintBottom_toBottomOf="@id/icon_coins"
            app:layout_constraintStart_toEndOf="@id/icon_coins"
            app:layout_constraintEnd_toEndOf="parent"/>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="fill_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            app:layout_constraintTop_toBottomOf="@id/reward_coins"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:id="@+id/correct"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/incorrect"
                app:layout_constraintHorizontal_chainStyle="spread"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

                <TextView
                    style="@style/Body.Small"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/correct"
                    android:textColor="@color/shade_secondary" />

                <TextView
                    style="@style/Label.Medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@{Integer.toString(resultstate.correct)}"
                    android:textColor="@color/shade_primary" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/incorrect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/correct"
                app:layout_constraintEnd_toEndOf="@id/skipped"
                app:layout_constraintBottom_toBottomOf="parent">
                <TextView
                    android:text="@string/incorrect"
                    style="@style/Body.Small"
                    android:textColor="@color/shade_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@{Integer.toString(resultstate.inCorrect)}"
                    style="@style/Label.Medium"
                    android:textColor="@color/shade_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/skipped"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toEndOf="@id/incorrect"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">
                <TextView
                    android:text="@string/skipped"
                    style="@style/Body.Small"
                    android:textColor="@color/shade_secondary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
                <TextView
                    android:text="@{Integer.toString(resultstate.skip)}"
                    style="@style/Label.Medium"
                    android:textColor="@color/shade_primary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>

</layout>