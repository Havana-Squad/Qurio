<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginHorizontal="8dp"
    android:layout_marginBottom="8dp"
    android:gravity="center">

    <ImageView
        android:id="@+id/img_achievement"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/lucky_guess2"
        android:contentDescription="collector" />

    <TextView
        android:id="@+id/tv_achievement_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        style="@style/Label.Small"
        android:text="Collector"
        android:textAlignment="center"
        android:textColor="@color/shade_primary" />

</LinearLayout>
