<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/game_img"
        android:src="@drawable/img_game_category_art"
        android:contentDescription="@string/game_img"
        android:layout_width="271dp"
        android:layout_height="344dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <View
        android:id="@+id/gradient_background"
        android:layout_width="222dp"
        android:layout_height="180dp"
        android:background="@drawable/game_item_shadow_purple"
        android:layout_marginBottom="20dp"
        app:layout_constraintBottom_toBottomOf="@id/game_img"
        app:layout_constraintStart_toStartOf="@id/game_img"
        app:layout_constraintEnd_toEndOf="@id/game_img"/>


    <TextView
        android:id="@+id/game_title"
        android:text="test1"
        android:textColor="@color/on_primary"
        style="@style/Label.Medium"
        android:layout_width="130dp"
        android:layout_height="wrap_content"
        android:maxLines="3"
        android:textAlignment="center"
        app:layout_constraintBottom_toTopOf="@id/play_btn"
        app:layout_constraintStart_toStartOf="@id/game_img"
        app:layout_constraintEnd_toEndOf="@id/game_img"
        android:layout_marginBottom="8dp"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/play_btn"
        android:background="@drawable/union_button_shape"
        android:layout_width="165dp"
        android:layout_height="44dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toBottomOf="@id/game_img"
        app:layout_constraintStart_toStartOf="@id/game_img"
        app:layout_constraintEnd_toEndOf="@id/game_img">
        <TextView
            android:text="@string/play_now"
            android:textColor="@color/on_primary"
            style="@style/Label.Small"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>