<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="5dp"
    android:clipChildren="false"
    android:clipToPadding="false">


    <androidx.cardview.widget.CardView
        android:id="@+id/card_question_card_back"
        style="@style/QuestionCardStyle"
        android:layout_width="match_parent"
        android:layout_height="108dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
       />

    <View
        android:layout_width="25dp"
        android:layout_height="10dp"
        android:background="@drawable/triangle_bottom"
        app:layout_constraintEnd_toEndOf="@id/card_question_card_back"
        app:layout_constraintStart_toStartOf="@id/card_question_card_back"
        app:layout_constraintTop_toBottomOf="@id/star"
        app:layout_constraintBottom_toBottomOf="@id/card_question_card_back"
        android:layout_marginBottom="-10dp"
        android:elevation="1dp"
        />
    <ImageView
        android:layout_width="254dp"
        android:layout_height="1dp"
        android:elevation="1dp"
        android:src="@drawable/faded_divider"
        app:layout_constraintEnd_toEndOf="@id/hexa"
        app:layout_constraintStart_toStartOf="@id/hexa"
        app:layout_constraintTop_toTopOf="@id/hexa"
        android:layout_marginTop="12dp"/>

    <ImageView
        android:id="@+id/hexa"
        android:layout_width="145dp"
        android:layout_height="40dp"
        android:layout_marginTop="-16dp"
        android:elevation="1dp"
        android:src="@drawable/ic_hexagon"
        app:layout_constraintEnd_toEndOf="@id/card_question_card_back"
        app:layout_constraintStart_toStartOf="@id/card_question_card_back"
        app:layout_constraintTop_toTopOf="@id/card_question_card_back" />



    <TextView
        android:id="@+id/question_date_text"
        style="@style/Label.Medium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="12dp"
        android:elevation="1dp"
        android:text=""
        android:textColor="@color/on_primary"
        app:layout_constraintEnd_toEndOf="@id/hexa"
        app:layout_constraintStart_toStartOf="@id/hexa"
        app:layout_constraintTop_toTopOf="@id/hexa"
        app:layout_constraintBottom_toBottomOf="@id/hexa"
        tools:text="31/05/2005" />

    <TextView
        android:id="@+id/genre"
        style="@style/Body.Small"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="1dp"
        android:lines="1"
        android:text=""
        android:textColor="@color/on_primary"
        app:layout_constraintEnd_toEndOf="@id/hexa"
        app:layout_constraintStart_toStartOf="@id/hexa"
        app:layout_constraintTop_toBottomOf="@id/hexa"
        tools:text="Science and Natural" />

    <LinearLayout
        android:id="@+id/coin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:elevation="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toStartOf="@id/divider1"
        app:layout_constraintHorizontal_chainStyle="spread"
        app:layout_constraintStart_toStartOf="@id/card_question_card_back"
        app:layout_constraintTop_toBottomOf="@id/genre">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:elevation="1dp"
            android:src="@drawable/ic_points" />

        <TextView
            style="@style/Label.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:elevation="1dp"
            android:textColor="@color/shade_primary"
            tools:text="777" />

    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:alpha="1"
        android:id="@+id/divider1"
        android:background="@color/shade_quad"
        android:elevation="1dp"
        app:layout_constraintBottom_toBottomOf="@+id/coin"
        app:layout_constraintStart_toEndOf="@id/coin"
        app:layout_constraintEnd_toStartOf="@id/star"
        app:layout_constraintTop_toTopOf="@id/coin" />

    <LinearLayout
        android:id="@+id/star"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:elevation="1dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintTop_toTopOf="@id/divider1"
        app:layout_constraintBottom_toBottomOf="@id/divider1"
        app:layout_constraintStart_toEndOf="@+id/divider1"
        app:layout_constraintEnd_toStartOf="@id/divider2">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:elevation="1dp"
            android:src="@drawable/ic_blue_star" />

        <TextView
            style="@style/Label.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="1dp"
            android:text=""
            android:layout_marginStart="4dp"
            android:textColor="@color/shade_primary"
            tools:text="7" />

    </LinearLayout>



    <View
        android:id="@+id/divider2"
        android:layout_width="1dp"
        android:layout_height="20dp"
        android:alpha="1"
        android:background="@color/shade_quad"
        android:elevation="1dp"
        app:layout_constraintBottom_toBottomOf="@+id/star"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintEnd_toStartOf="@id/time"
        app:layout_constraintStart_toEndOf="@id/star"
        app:layout_constraintTop_toTopOf="@id/star" />

    <LinearLayout
        android:id="@+id/time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:elevation="1dp"
        app:layout_constraintEnd_toEndOf="@id/card_question_card_back"
        app:layout_constraintStart_toEndOf="@+id/divider2"
        android:layout_marginStart="24dp"
        android:gravity="center_vertical"
        android:layout_marginEnd="16dp"
        app:layout_constraintTop_toTopOf="@id/star">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:elevation="1dp"
            android:src="@drawable/ic_clock"/>

        <TextView
            style="@style/Label.Medium"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:elevation="1dp"
            android:layout_marginStart="4dp"
            android:text=""
            android:textColor="@color/shade_primary"
            tools:text="777" />
    </LinearLayout>


</androidx.constraintlayout.widget.ConstraintLayout>