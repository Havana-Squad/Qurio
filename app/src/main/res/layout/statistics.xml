<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:tools="http://schemas.android.com/tools"
    android:clipChildren="false"
    android:clipToPadding="false"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="96dp"
        android:layout_height="50dp"
        android:id="@+id/lives_container"
        app:layout_constraintStart_toStartOf="parent"
        android:background="@drawable/bg_lives"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_plus_circle"
            android:translationX="-2dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/lives_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="7dp"
            android:text="@string/lives"
            android:textAppearance="@style/Label.XSmall"
            android:textColor="@color/shade_tertiary"/>

        <ImageView
            android:id="@+id/lives_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_gold_heart"
            app:layout_constraintEnd_toStartOf="@+id/lives_count"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lives_label" />


        <TextView
            android:id="@+id/lives_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="1dp"
            android:textAppearance="@style/Label.Medium"
            android:textColor="@color/shade_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/lives_icon"
            app:layout_constraintTop_toTopOf="@id/lives_icon"
            app:layout_constraintBottom_toBottomOf="@id/lives_icon"
            tools:text="4" />


        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@drawable/bg_statistics_indicator"
            android:layout_marginBottom="0.5dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="144dp"
        android:layout_height="66dp"
        android:id="@+id/points_container"
        app:layout_constraintStart_toEndOf="@id/lives_container"
        android:background="@drawable/bg_points"
        app:layout_constraintBottom_toBottomOf="parent">
<!--        TODO: Show if points >= 10000-->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="20dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:src="@drawable/ic_crown"
            android:visibility="visible"
            android:translationY="-10dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/points_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="17dp"
            android:text="@string/points"
            android:textAppearance="@style/Label.XSmall"
            android:textColor="@color/shade_tertiary"/>

        <ImageView
            android:id="@+id/points_icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_points"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/points_count"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/points_label" />

        <TextView
            android:id="@+id/points_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1dp"
            android:layout_marginStart="4dp"
            android:textAppearance="@style/Label.Medium"
            android:textColor="@color/shade_primary"
            app:layout_constraintBottom_toBottomOf="@id/points_icon"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@+id/points_icon"
            app:layout_constraintTop_toTopOf="@id/points_icon"
            tools:text="5200" />

        <View
            android:layout_width="67dp"
            android:layout_height="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@drawable/bg_statistics_indicator"
            android:layout_marginBottom="0.5dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="96dp"
        android:layout_height="50dp"
        android:id="@+id/awards_container"
        app:layout_constraintStart_toEndOf="@id/points_container"
        android:background="@drawable/bg_awards"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:id="@+id/awards_label"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_marginTop="7dp"
            android:text="@string/awards"
            android:textAppearance="@style/Label.XSmall"
            android:textColor="@color/shade_tertiary"/>

        <ImageView
            android:id="@+id/awards_icon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_trophy"
            app:layout_constraintEnd_toStartOf="@+id/awards_count"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/awards_label" />

        <TextView
            android:id="@+id/awards_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_marginTop="1dp"
            android:textAppearance="@style/Label.Medium"
            android:textColor="@color/shade_primary"
            app:layout_constraintEnd_toStartOf="@id/btn_upgrade_awards"
            app:layout_constraintStart_toEndOf="@+id/awards_icon"
            app:layout_constraintTop_toTopOf="@id/awards_icon"
            app:layout_constraintBottom_toBottomOf="@id/awards_icon"
            tools:text="2" />

        <ImageView
            android:id="@+id/btn_upgrade_awards"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="2dp"
            android:src="@drawable/ic_arrow_right_circle"
            android:layout_marginStart="8dp"
            app:layout_constraintStart_toEndOf="@+id/awards_count"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/awards_icon"
            app:layout_constraintBottom_toBottomOf="@id/awards_icon"/>

        <View
            android:layout_width="48dp"
            android:layout_height="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:background="@drawable/bg_statistics_indicator"
            android:layout_marginBottom="0.5dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>